# ============================================================
#  s3-xlsx-importer — Variáveis de Ambiente
#  Copie este arquivo para .env e preencha os valores reais.
#  O arquivo .env deve ficar na mesma pasta que o JAR.
# ============================================================

# ---------- AWS ----------
AWS_ACCESS_KEY_ID=ASIARFCPMZBDLJZ5JNB6
AWS_SECRET_ACCESS_KEY=G+241/y1kgq7cqyOMFoZjqC9U+baeBdsxd/vrhWN
# Obrigatório para credenciais temporárias (access key começa com ASIA)
AWS_SESSION_TOKEN=SEU_SESSION_TOKEN_AQUI
AWS_REGION=us-east-1

# Nome do bucket S3 onde estão os arquivos XLSX
S3_BUCKET_NAME=vision-score-s3

# Prefixo (pasta) dentro do bucket (deixe em branco para raiz)
S3_PREFIX=

# ---------- Banco de Dados MySQL ----------
DB_URL=jdbc:mysql://localhost:3306/testeJar
DB_USERNAME=root
DB_PASSWORD=1234

# ---------- Configurações de Import ----------
# Tamanho do lote para inserções em batch (padrão: 500)
BATCH_SIZE=500
# ---------- Configurações de linhas para serem lidas, para fins de teste ----------
# Limite de linhas por arquivo para testes (0 = processa tudo)
MAX_LINHAS_TESTE=1000
